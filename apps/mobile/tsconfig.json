{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["ES2022"],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@hackatone/shared": ["../../packages/shared/src/index.ts"],
      "@hackatone/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["app/**/*", "src/**/*", "app.json"]
}
